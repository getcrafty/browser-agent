{
	"name": "browser-agent",
	"version": "1.0.9",
	"repository": "https://github.com/getcrafty/browser-agent",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"browser-agent": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./core": {
			"types": "./dist/core/index.d.ts",
			"import": "./dist/core/index.js"
		},
		"./llm-capabilities": {
			"types": "./dist/llm-capabilities.d.ts",
			"import": "./dist/llm-capabilities.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"RPC.md",
		"assets/crafty-mark.svg"
	],
	"scripts": {
		"start": "tsx src/cli.ts",
		"prepack": "npm run build",
		"clean": "node ./scripts/clean-dist.mjs",
		"build": "npm run clean && tsc && node ./scripts/clean-build-output.mjs",
		"build:sdk-binary": "node ./scripts/build-sdk-binary.mjs",
		"build:watch": "tsc -w --preserveWatchOutput",
		"test:python-sdk": "uv run --project sdk/python-sdk python scripts/test-python-sdk.py",
		"test:sdk-binary": "node ./scripts/smoke-sdk-binary.mjs",
		"test:typescript-sdk": "tsx scripts/test-typescript-sdk.ts",
		"test": "mocha --timeout 60000 --node-option=import=tsx \"tests/**/*.ts\"",
		"test:auth-prompt-safety:coverage": "c8 --all --check-coverage --lines 100 --functions 100 --branches 100 --statements 100 --include=src/auth/runtime.ts --include=src/core/step.ts --include=src/core/history-adapter.ts --include=src/agents/executor-utils/history-payload.ts mocha --timeout 180000 --node-option=import=tsx tests/auth-runtime.unit.ts tests/auth-prompt-protection.unit.ts tests/core-api.unit.ts tests/history-prompt-safety.unit.ts",
		"test:e2e-together": "mocha --timeout 300000 --node-option=import=tsx \"tests/**/*.e2e.ts\"",
		"report:task-outcomes": "tsx scripts/report-task-outcomes.ts"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.68",
		"@ai-sdk/google": "^3.0.60",
		"@ai-sdk/openai": "^3.0.52",
		"@ai-sdk/openai-compatible": "^2.0.41",
		"@aws-sdk/client-s3": "^3.1090.0",
		"@napi-rs/canvas": "^0.1.100",
		"@openrouter/ai-sdk-provider": "2.9.1",
		"@tesseract.js-data/eng": "^1.0.0",
		"ai": "^6.0.154",
		"chrome-launcher": "^1.2.1",
		"chrome-remote-interface": "^0.33.2",
		"dotenv": "^16.4.7",
		"js-yaml": "^4.1.1",
		"markitdown-ts": "^0.0.10",
		"openai": "^6.22.0",
		"pdfjs-dist": "^5.4.624",
		"promise-limit": "^2.7.0",
		"readline": "^1.3.0",
		"sharp": "^0.34.5",
		"tesseract.js": "^7.0.0",
		"tiktoken": "^1.0.22",
		"tldts": "^7.0.13",
		"unzipper": "^0.12.5",
		"xlsx": "^0.18.5",
		"youtube-transcript": "^1.3.1"
	},
	"devDependencies": {
		"@types/chai": "^5.2.0",
		"@types/chrome-remote-interface": "^0.31.14",
		"@types/js-yaml": "^4.0.9",
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.0.0",
		"bun": "1.3.14",
		"c8": "^11.0.0",
		"chai": "^5.2.0",
		"mocha": "^11.1.0",
		"tsx": "^4.19.0",
		"typescript": "^5.9.3"
	}
}
